{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git_dir=$(git rev-parse --show-toplevel 2>/dev/null || pwd) && bash \"$git_dir/scripts/session_start_hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git_dir=$(git rev-parse --show-toplevel 2>/dev/null || pwd) && bash \"$git_dir/scripts/stop_hook_inbox.sh\"",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "git_dir=$(git rev-parse --show-toplevel 2>/dev/null || pwd) && bash \"$git_dir/scripts/shogun_stop_telegram_forward.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /mnt/*)",
      "Bash(rm -rf /mnt/c/*)",
      "Bash(rm -rf /home/*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(tmux kill-server*)",
      "Bash(tmux kill-session*)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(chmod -R * /)",
      "Bash(chown -R * /)"
    ]
  },
