# Telegram Bot Authentication Configuration
#
# Usage:
#   1. Copy this file to config/telegram.env
#   2. Fill in your credentials (this file is git-ignored by default)
#
# To get a bot token:
#   1. Message @BotFather on Telegram.
#   2. Send /newbot and follow the instructions to get the API Token.
#
# To get your chat ID:
#   1. Send a message to your new bot.
#   2. Message @userinfobot or visit https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
#   3. Find the "chat": {"id": ...} field in the JSON response.

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
