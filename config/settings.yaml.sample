# ═══════════════════════════════════════════════════════════════
# multi-agent-shogun — canonical settings sample
#
# Copy to config/settings.yaml and customize. config/settings.yaml
# is gitignored (per project convention); only this sample template
# is committed to the repository.
#
# The default topology is v2 (shogun + orchestrator + 9 specialists).
# Exactly 11 roles must be defined:
#   shogun, orchestrator, surveyor, critic, architect, experimentalist,
#   analyst, ablation_planner, writer, observer, council.
# ═══════════════════════════════════════════════════════════════

language: en
shell: bash
topology: v2

# Tmux session suffix (useful when running multiple shogun project environments simultaneously).
# Options:
#   - "": No suffix (default, session names are "shogun" and "multiagent")
#   - "auto": Dynamically suffix with the current directory name (e.g. "-my-project-dir")
#   - Any custom string (e.g. "-proj-a", "-research")
session_suffix: ""

skill:
  save_path: "~/.claude/skills/"
  local_path: "./skills/"

logging:
  level: info
  path: "./logs/"

cli:
  default: claude

roles:
  shogun:
    model: opus
    cli_variant: claude
    pane_target: "shogun:main.0"
    color: "#002b36"
    title: "shogun"
    prompt_path: "instructions/shogun.md"
    temperature: 0.1
    skills: [zoom-out, grill-with-docs]
    permissions_override: {}

  orchestrator:
    model: opus
    cli_variant: claude
    pane_target: "multiagent:ops.0"
    color: "#501515"
    title: "orchestrator"
    prompt_path: "instructions/orchestrator.md"
    temperature: 0.1
    skills: []
    permissions_override:
      read_allow:
        - "queue/inbox/orchestrator.yaml"
        - "queue/tasks/*.yaml"
        - "queue/reports/*.yaml"
        - "context/*"
        - "dashboard.md"
      edit_allow:
        - "queue/tasks/*.yaml"
        - "queue/tasks/pending.yaml"
        - "dashboard.md"
      edit_deny:
        - "queue/reports/*.yaml"

  architect:
    model: opus
    cli_variant: claude
    pane_target: "multiagent:ops.1"
    color: "#1e3a1e"
    title: "architect"
    prompt_path: "instructions/architect.md"
    temperature: 0.1
    skills: [spec-driven-development, api-and-interface-design]
    permissions_override:
      edit_deny: ["**/*"]

  experimentalist:
    model: sonnet
    cli_variant: claude
    pane_target: "multiagent:ops.2"
    color: "#1e3a3a"
    title: "experimentalist"
    prompt_path: "instructions/experimentalist.md"
    temperature: 0.2
    skills: [subagent-driven-development, test-driven-development, incremental-implementation, debugging-and-error-recovery]
    permissions_override: {}

  analyst:
    model: sonnet
    cli_variant: claude
    pane_target: "multiagent:ops.3"
    color: "#3a1e3a"
    title: "analyst"
    prompt_path: "instructions/analyst.md"
    temperature: 0.1
    skills: []
    permissions_override:
      edit_deny: ["**/*"]

  ablation_planner:
    model: sonnet
    cli_variant: claude
    pane_target: "multiagent:ops.4"
    color: "#503515"
    title: "ablation_planner"
    prompt_path: "instructions/ablation_planner.md"
    temperature: 0.1
    skills: []
    permissions_override:
      edit_deny: ["**/*"]

  surveyor:
    model: haiku
    cli_variant: claude
    pane_target: "multiagent:research.0"
    color: "#454510"
    title: "surveyor"
    prompt_path: "instructions/surveyor.md"
    temperature: 0.1
    skills: [web-search, doc-fetch]
    permissions_override:
      read_allow: ["context/*"]
      edit_deny: ["**/*"]

  critic:
    model: opus
    cli_variant: claude
    pane_target: "multiagent:research.1"
    color: "#9e7c0a"
    title: "critic"
    prompt_path: "instructions/critic.md"
    temperature: 0.1
    skills: [doubt-driven-development]
    permissions_override:
      edit_deny: ["**/*"]

  writer:
    model: sonnet
    cli_variant: claude
    pane_target: "multiagent:research.2"
    color: "#353535"
    title: "writer"
    prompt_path: "instructions/writer.md"
    temperature: 0.2
    skills: []
    permissions_override: {}

  observer:
    model: sonnet
    cli_variant: claude
    pane_target: "multiagent:research.3"
    color: "#1c2a38"
    title: "observer"
    prompt_path: "instructions/observer.md"
    temperature: 0.2
    skills: []
    permissions_override:
      edit_deny: ["**/*"]

  council:
    model: opus
    cli_variant: claude
    pane_target: "multiagent:research.4"
    color: "#2b2b2b"
    title: "council"
    prompt_path: "instructions/council.md"
    temperature: 0.1
    skills: []
    permissions_override:
      edit_deny: ["**/*"]
